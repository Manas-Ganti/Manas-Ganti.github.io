---
import { Icon } from "astro-icon/components";
import { type ResearchEntry, statusClass, statusLabel } from "@/data/research";
import { siteConfig } from "@/site.config";

interface Props {
	entry: ResearchEntry;
	/** Compact form for the home page: no author list. */
	compact?: boolean;
}

const { compact = false, entry } = Astro.props;
const { arxiv, authors, code, draft, finding, status, title, venue } = entry.data;
const href = `/research/${entry.id}/`;
---

<article class="border-muted/30 relative border-t pt-6" id={entry.id}>
	<div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
		<h3 class="text-accent-2 text-lg font-semibold">
			{/* Stretched link: the whole card is the click target for the write-up. */}
			<a class="cactus-link after:absolute after:inset-0" href={href}>{title}</a>
		</h3>
		<span
			class:list={["rounded-full border px-2 py-0.5 text-xs font-semibold", statusClass[status]]}
		>
			{statusLabel({ status, venue })}
		</span>
		{
			draft && (
				<span class="border-muted text-muted rounded-full border px-2 py-0.5 text-xs font-semibold">
					Draft — hidden in production
				</span>
			)
		}
	</div>

	<p class="mt-2">{finding}</p>

	{
		!compact && (
			<p class="text-muted mt-2 text-xs">
				{authors.map((author, i) => (
					<>
						{i > 0 && ", "}
						{author === siteConfig.author ? <strong class="text-accent-2">{author}</strong> : author}
					</>
				))}
			</p>
		)
	}

	{/* z-10 lifts these above the stretched link so they stay individually clickable. */}
	<div class="relative z-10 mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
		{
			arxiv && (
				<a class="cactus-link inline-flex items-center gap-x-1" href={arxiv} rel="noreferrer" target="_blank">
					<Icon aria-hidden="true" class="h-4 w-4" focusable="false" name="mdi:file-document-outline" />
					Paper
				</a>
			)
		}
		{
			code && (
				<a class="cactus-link inline-flex items-center gap-x-1" href={code} rel="noreferrer" target="_blank">
					<Icon aria-hidden="true" class="h-4 w-4" focusable="false" name="mdi:github" />
					Code
				</a>
			)
		}
		<a class="cactus-link text-muted ms-auto" href={href}>Read the write-up &rarr;</a>
	</div>
</article>
